{
  "name": "Escala Agro API",
  "dockerComposeFile": ["../docker-compose.yml", "../docker-compose.devcontainer.yml"],
  "service": "api",
  "workspaceFolder": "/app",
  "forwardPorts": [4001, 5545],
  "postCreateCommand": "npm install && npx sequelize-cli db:migrate",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}

NODE_ENV=stage
# API local (fora do Docker): 3000. Com stack Docker, acesso pelo host: http://localhost:4001
PORT=3000

# Docker: defina DOCKER_CONTAINER=true no docker-compose; use host "postgres" no serviço.
DOCKER_CONTAINER=false

# A partir do host (Windows) com Postgres do docker-compose publicado em 5545:5432:
DB_HOST=127.0.0.1
DB_PORT=5545
DB_USER=escala
DB_PASSWORD=escala
DB_DATABASE=escala_agro
